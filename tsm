#!/bin/bash

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tsm"
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/tsm/logs"
mkdir -p "$CONFIG_DIR" "$LOG_DIR"

TSM_DIRS_CMD_DEFAULT='find "$HOME" -maxdepth 4 -name ".*" -prune -o -type d \( -exec test -e {}/.git \; -print -prune -o -print \)'
TSM_GIT_DIRS_CMD_DEFAULT='find "$HOME" -maxdepth 4 -name ".*" -prune -o -type d -exec test -e {}/.git \; -print -prune 2>/dev/null'

usage() {
  echo "Tmux Session Manager"
  echo ""
  echo "Usage: tsm [session] [options]"
  echo ""
  echo "Options:"
  echo "  -h, --help               Show this help message"
  echo "  -c, --configured [name]  Browse configured sessions with fzf, or start session if provided"
  echo "  -d, --dir [path]         Browse directories with fzf, or start session at path if provided"
  echo "  -z, --zoxide [query]     Browse zoxide entries with fzf, or query zoxide if provided"
  echo "  -g, --git [--hide-brief] [--no-fetch] Browse git repositories with fzf"
  echo "  -w, --worktree [name]    Browse worktrees for current git repo with fzf, or start worktree if provided"
  echo "  -k, --kill [name]        Run kill(), if it exists, and kill the session"
  echo "  -l, --logs [name]        Browse all log files, or for named session if provided"
  echo ""
  echo "Examples:"
  echo "  tsm                Browse active sessions with fzf"
  echo "  tsm myproject      Switch to active session"
  echo "  tsm -c             Browse configured sessions with fzf"
  echo "  tsm -c myproject   Start configured session"
  echo "  tsm -d             Browse directories with fzf"
  echo "  tsm -d ~/projects  Start session at ~/projects"
  echo "  tsm -z             Browse zoxide entries interactively"
  echo "  tsm -z proj        Start session at best zoxide match for 'proj'"
  echo "  tsm -g             Browse git repositories with fzf"
  echo "  tsm -w             Browse worktrees for current git repo"
  echo "  tsm -w other       Start session for worktree named 'other'"
  echo "  tsm -k             Select session to kill with fzf"
  echo "  tsm -k myproject   Kill session"
  echo "  tsm -l             Browse all log files with fzf"
  echo "  tsm -l myproject   Browse log files for named session with fzf"
  echo ""
  echo "Configuration:"
  echo "  Sessions are configured as \$HOME/.config/tsm/<config-name>.sh"
  echo ""
  echo "  <config-name>.sh    Script containing session configuration:"
  echo ""
  echo "            SESSION variable:  Required. The tmux session name."
  echo "            start()            Required. Creates and customizes the tmux session."
  echo "            kill()             Optional. Runs asynchronously when session is killed."
  echo "                               Use this for cleanup tasks like stopping services."
  echo ""
  echo "Environment Variables:"
  echo "  TSM_DIRS_CMD              Command to generate directories for 'tsm -d'."
  echo "                            The command is evaluated at runtime and piped to fzf."
  echo "                            Default (when unset): non-hidden directories within 5 levels of \$HOME,"
  echo "                            pruning at git repo roots"
  echo ""
  echo "  TSM_GIT_DIRS_CMD          Command to generate git repository paths for 'tsm -g'."
  echo "                            The command is evaluated at runtime. Each line should be a repo path."
  echo "                            Default (when unset): directories containing .git within 5 levels of \$HOME"
  echo ""
  echo "  EDITOR                    Editor used by 'tsm -l' when opening a log file with ctrl-o."
  echo "                            Falls back to vi if not set."
}

####################
# helper functions #
####################
notify() {
  # Displays a message to the user.
  # Uses tmux display-message when running inside tmux, otherwise falls back to echo.
  local msg="$1"
  if [ -n "$TMUX" ]; then
    tmux display-message "$msg"
  else
    echo "$msg"
  fi
}

get_active_sessions() {
  # Lists active tmux session names, one per line.
  tmux ls 2>/dev/null | awk -F: '{print $1}'
}

switch_or_attach() {
  # Switches to a tmux session if inside tmux, otherwise attaches to it.
  local session="$1"
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "=$session"
  else
    tmux attach-session -t "=$session"
  fi
}

sanitize_directory_session_name() {
  # Converts a directory path to a valid tmux session name by taking the
  # basename and replacing non-alphanumeric characters (except _ and -) with _.
  basename "$1" | tr -c 'a-zA-Z0-9_\-\n' '_'
}

git_brief(){
  # Returns a brief git status for the repo located in $1
  # Format: branch ↑ahead↓behind +insertions-deletions
  local dir="$1"
  local no_fetch="$2"
  local branch ahead behind stats added removed

  branch=$(git -C "$dir" branch --show-current 2>/dev/null) || return
  [ "$no_fetch" != "--no-fetch" ] && git -C "$dir" fetch --quiet 2>/dev/null
  ahead=$(git -C "$dir" log @{u}..HEAD --oneline 2>/dev/null | wc -l | tr -d ' ')
  behind=$(git -C "$dir" log HEAD..@{u} --oneline 2>/dev/null | wc -l | tr -d ' ')
  stats=$(git -C "$dir" diff --shortstat 2>/dev/null)
  added=$(echo "$stats" | grep -o '[0-9]* insertion' | grep -o '[0-9]*')
  removed=$(echo "$stats" | grep -o '[0-9]* deletion' | grep -o '[0-9]*')

  local blue='\033[34m' yellow='\033[33m' green='\033[32m' red='\033[31m' reset='\033[0m'
  local out="${blue}${branch}${reset}"
  [ "${ahead:-0}" -gt 0 ] && out+=" ${yellow}↑${ahead}${reset}"
  [ "${behind:-0}" -gt 0 ] && out+=" ${yellow}↓${behind}${reset}"
  [ "${added:-0}" -gt 0 ] && out+=" ${green}+${added}${reset}"
  [ "${removed:-0}" -gt 0 ] && out+=" ${red}-${removed}${reset}"
  printf '%b\n' "$out"
}

session_name_prompt() {
  # Prompts the user for a session name.
  # Provides a sensible default that can be used if no input is given.
  # Echoes the final session name.
  #
  # Args:
  #   $1: path — directory to derive the session name from
  local path="$1"
  local default_name

  local git_dir
  git_dir=$(git -C "$path" rev-parse --git-dir 2>/dev/null)

  if [ -n "$git_dir" ] && [ "$git_dir" != ".git" ]; then
    # Worktree — git_dir is absolute, e.g. /path/to/.bare/worktrees/wt_name
    local bare_repo_path
    bare_repo_path=$(dirname "$(dirname "$git_dir")")
    local bare_leaf
    bare_leaf=$(basename "$bare_repo_path")

    local repo_name
    if [ "$bare_leaf" = ".bare" ] || [ "$bare_leaf" = ".git" ]; then
      repo_name=$(basename "$(dirname "$bare_repo_path")")
    else
      repo_name="$bare_leaf"
    fi

    local worktree_name
    worktree_name=$(basename "$path")

    default_name="$(sanitize_directory_session_name "$repo_name")/${worktree_name}"
  else
    default_name=$(sanitize_directory_session_name "$path")
  fi

  local session_name="$default_name"
  printf "%s\n" "$(tput setaf 8)$path$(tput sgr0)" >&2
  while true; do
    local prompt="Enter session name"
    if ! tmux has-session -t "=$session_name" 2>/dev/null; then
      prompt="$prompt [$(tput setaf 4)${session_name}$(tput sgr0)]"
    fi
    read -rp "$prompt: " user_input
    session_name="${user_input:-$session_name}"
    if ! tmux has-session -t "=$session_name" 2>/dev/null; then
      break
    fi
    printf "$(tput setaf 1)Session '%s' already exists.$(tput sgr0)\n" "$session_name" >&2
  done
  echo "$session_name"
}

#################
# api functions #
#################
active_session() {
  local session="$1"

  # If no session provided, use fzf to select from active sessions
  if [ -z "$session" ]; then
    local active_sessions
    active_sessions=$(get_active_sessions)

    if [ -z "$active_sessions" ]; then
      notify "No active sessions"
      exit 1
    fi

    session=$(echo "$active_sessions" | fzf --cycle --prompt "> " --header "Select active session")

    if [ -z "$session" ]; then
      exit 0
    fi
  fi

  if ! tmux has-session -t "=$session" 2>/dev/null; then
    notify "Error: Session '$session' is not running"
    exit 1
  fi

  switch_or_attach "$session"
}

kill_session() {
  local session="$1"

  # If no session provided, use fzf to select from active sessions
  if [ -z "$session" ]; then
    local active_sessions
    active_sessions=$(get_active_sessions)

    if [ -z "$active_sessions" ]; then
      notify "No active sessions to kill"
      exit 1
    fi

    session=$(echo "$active_sessions" | fzf --cycle --prompt "> " --header "Kill session")

    if [ -z "$session" ]; then
      exit 0
    fi
  fi

  if ! tmux has-session -t "=$session" 2>/dev/null; then
    notify "Error: Session '$session' is not running"
    exit 1
  fi

  local log_dir="$LOG_DIR/$session"
  local log_file="$log_dir/tsm.log"
  mkdir -p "$log_dir"

  local configured_session
  configured_session=$(tmux show-environment -t "=$session" TSM_CONFIGURED_SESSION 2>/dev/null | sed 's/^TSM_CONFIGURED_SESSION=//')
  local session_file="$CONFIG_DIR/${configured_session:-$session}.sh"

  # Run kill function in background if it exists
  if [ -f "$session_file" ]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Killing session '$session'" > "$log_file"
    nohup bash -c "source '$session_file' && declare -F kill &>/dev/null && kill" >> "$log_file" 2>&1 &
  fi

  tmux kill-session -t "=$session"
}

configured_session() {
  local config="$1"

  if [ ! -d "$CONFIG_DIR" ]; then
    notify "No sessions configured. Create files in $CONFIG_DIR"
    exit 1
  fi

  # If no config provided, use fzf to select from configured sessions
  if [ -z "$config" ]; then
    local configured_sessions
    configured_sessions=$(for f in "$CONFIG_DIR"/*.sh; do [ -f "$f" ] && basename "$f" .sh; done)

    if [ -z "$configured_sessions" ]; then
      notify "No configured sessions"
      exit 1
    fi

    config=$(echo "$configured_sessions" | fzf --cycle --prompt "> " --header "Select configured session")

    if [ -z "$config" ]; then
      exit 0
    fi
  fi

  local session_file="$CONFIG_DIR/$config.sh"

  if [ ! -f "$session_file" ]; then
    notify "Error: '$config' not found in $CONFIG_DIR"
    exit 1
  fi

  # Verify start function exists
  if ! bash -c "source '$session_file' && declare -F start" &>/dev/null; then
    notify "Error: No start function defined in $config.sh"
    exit 1
  fi

  # Read SESSION from config file
  local session
  session=$(bash -c "source '$session_file' && echo \"\$SESSION\"")

  if [ -z "$session" ]; then
    notify "Error: SESSION variable not defined in $config.sh"
    exit 1
  fi

  if tmux has-session -t "=$session" 2>/dev/null; then
    switch_or_attach "$session"
    return
  fi

  local log_dir="$LOG_DIR/$session"
  local log_file="$log_dir/tsm.log"
  mkdir -p "$log_dir"
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting session '$session'" > "$log_file"
  bash -c "set -m; source '$session_file' && start" >> "$log_file" 2>&1
  tmux set-environment -t "=$session" TSM_CONFIGURED_SESSION "$config"
  switch_or_attach "$session"
}

dir_session() {
  local target_dir="$1"
  local selected

  if [ -n "$target_dir" ]; then
    # Path provided, use it directly
    # Expand tilde if present
    selected="${target_dir/#\~/$HOME}"

    if [ ! -d "$selected" ]; then
      notify "Error: Directory '$selected' does not exist"
      exit 1
    fi
  else
    # No path provided, use fzf to select from TSM_DIRS_CMD or default
    local dirs_cmd="${TSM_DIRS_CMD:-$TSM_DIRS_CMD_DEFAULT}"

    # Use process substitution to allow killing the directory generator after fzf exits
    exec 3< <(eval "$dirs_cmd")
    local dirs_pid=$!
    selected=$(fzf --cycle --prompt "> " --header "Select directory" <&3)
    kill "$dirs_pid" 2>/dev/null
    wait "$dirs_pid" 2>/dev/null
    exec 3<&-

    if [ -z "$selected" ]; then
      exit 0
    fi
  fi

  # Resolve to absolute path
  selected=$(cd "$selected" && pwd -P)

  # Create the session
  session_name=$(session_name_prompt "$selected")
  tmux new-session -d -s "$session_name" -c "$selected"
  switch_or_attach "$session_name"
}

zoxide_session() {
  local query="$1"
  local selected

  if ! command -v zoxide &> /dev/null; then
    notify "Error: zoxide is not installed"
    exit 1
  fi

  if [ -n "$query" ]; then
    # Query provided, use zoxide query directly
    selected=$(zoxide query "$query" 2>/dev/null)

    if [ -z "$selected" ]; then
      notify "Error: No zoxide match found for '$query'"
      exit 1
    fi
  else
    # No query provided, use zoxide query -i for interactive selection
    selected=$(zoxide query -i 2>/dev/null)

    if [ -z "$selected" ]; then
      exit 0
    fi
  fi

  dir_session "$selected"
}

git_session() {
  local hide_brief="" no_fetch=""
  for arg in "$@"; do
    case "$arg" in
      --hide-brief) hide_brief=1 ;;
      --no-fetch) no_fetch="--no-fetch" ;;
    esac
  done
  local git_dirs_cmd="${TSM_GIT_DIRS_CMD:-$TSM_GIT_DIRS_CMD_DEFAULT}"

  local dirs selected
  dirs=$(eval "$git_dirs_cmd" | sort)

  if [ -z "$dirs" ]; then
    notify "No git repositories found"
    exit 1
  fi

  if [ -n "$hide_brief" ]; then
    selected=$(echo "$dirs" | fzf --cycle --prompt "> " --header "Select git repository")
  else
    if [ -z "$no_fetch" ]; then
      while read -r dir; do
        git -C "$dir" fetch --quiet 2>/dev/null &
      done <<< "$dirs"
      wait
    fi

    selected=$(echo "$dirs" \
      | while read -r dir; do
          printf '%s\t%s  %s\n' "$dir" "$dir" "$(git_brief "$dir" --no-fetch)"
        done \
      | fzf --ansi --cycle --delimiter=$'\t' --with-nth=2 --prompt "> " --header "Select git repository")
    selected="${selected%%	*}"
  fi

  if [ -z "$selected" ]; then
    exit 0
  fi

  dir_session "$selected"
}

worktree_session() {
  local name="$1"
  local worktree_data
  worktree_data=$(git worktree list --porcelain | awk '
    /^worktree / { path = substr($0, 10); branch = "" }
    /^branch / { branch = substr($0, 8); sub("refs/heads/", "", branch) }
    /^bare$/ { path = "" }
    /^$/ { if (path != "") print path "\t" (branch != "" ? branch : "(detached)"); path = ""; branch = "" }
    END { if (path != "") print path "\t" (branch != "" ? branch : "(detached)") }
  ')

  if [ -z "$worktree_data" ]; then
    notify "No worktrees found"
    exit 0
  fi

  local selected
  if [ -n "$name" ]; then
    selected=$(echo "$worktree_data" | while IFS=$'\t' read -r wt _; do
      if [ "${wt##*/}" = "$name" ]; then
        echo "$wt"
        break
      fi
    done)

    if [ -z "$selected" ]; then
      notify "No worktree found matching '$name'"
      exit 1
    fi
  else
    local fzf_input max_name=0 max_branch=0
    while IFS=$'\t' read -r wt branch; do
      local wt_name="${wt##*/}"
      (( ${#wt_name} > max_name )) && max_name=${#wt_name}
      (( ${#branch} > max_branch )) && max_branch=${#branch}
    done <<< "$worktree_data"
    fzf_input=$(echo "$worktree_data" | while IFS=$'\t' read -r wt branch; do
      printf '%s\t%-*s  \033[32m%-*s\033[0m  %s\n' "$wt" "$max_name" "${wt##*/}" "$max_branch" "$branch" "$wt"
    done)

    selected=$(echo "$fzf_input" | fzf --ansi --cycle --with-nth=2 --delimiter=$'\t' --prompt "> " --header "Select worktree")

    if [ -z "$selected" ]; then
      exit 0
    fi

    selected="${selected%%	*}"
  fi

  dir_session "$selected"
}

browse_logs() {
  local session="$1"

  local search_dir
  if [ -n "$session" ]; then
    search_dir="$LOG_DIR/$session"
    if [ ! -d "$search_dir" ]; then
      notify "Error: No log directory found for session '$session'"
      exit 1
    fi
  else
    search_dir="$LOG_DIR"
  fi

  local log_files
  log_files=$(find "$search_dir" -type f -name '*.log' 2>/dev/null | sed "s|^$LOG_DIR/||" | sort)

  if [ -z "$log_files" ]; then
    notify "No log files found"
    exit 1
  fi

  local selected
  selected=$(echo "$log_files" | fzf \
    --cycle \
    --bind=ctrl-d:preview-half-page-down \
    --bind=ctrl-u:preview-half-page-up \
    --bind="ctrl-o:execute(${EDITOR:-vi} '$LOG_DIR/{}')" \
    --prompt "> " \
    --header $':: \e[33mEnter\e[0m to \e[31mtail\e[0m | \e[33mctrl-o\e[0m to \e[31mopen in editor\e[0m | \e[33mctrl-d\e[0m to \e[31mpreview page down\e[0m | \e[33mctrl-u\e[0m to \e[31mpreview page up\e[0m' \
    --preview "tail -n 100000 -f '$LOG_DIR/{}'" \
    --preview-window follow)

  if [ -z "$selected" ]; then
    exit 0
  fi

  tail -n 1000 -f "$LOG_DIR/$selected"
}

# Parse arguments
if [ $# -eq 0 ]; then
  active_session
  exit 0
fi

case "$1" in
  -c|--configured)
    configured_session "$2"
    ;;
  -k|--kill)
    kill_session "$2"
    ;;
  -l|--logs)
    browse_logs "$2"
    ;;
  -g|--git)
    shift; git_session "$@"
    ;;
  -d|--dir)
    dir_session "$2"
    ;;
  -z|--zoxide)
    zoxide_session "$2"
    ;;
  -w|--worktree)
    worktree_session "$2"
    ;;
  -h|--help)
    usage
    ;;
  -*)
    notify "Error: Unknown option '$1'"
    usage
    exit 1
    ;;
  *)
    active_session "$1"
    ;;
esac
